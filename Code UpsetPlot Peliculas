import pandas as pd
import matplotlib.pyplot as plt
from upsetplot import UpSet

# Leemos el CSV con la informacion de las peliculas
df = pd.read_csv(r"C:\Users\mehdi\OneDrive\Bureau\movies.csv")

# Definimos los géneros que queremos analizar
genres = ["Drama", "Comedy", "Thriller", "Action", "Romance", "Adventure", "Crime"]

# Convertimos la columna 'genres' en columnas binarias
df = df.join(df['genres'].str.get_dummies('|'))

# Filtramos solo las peliculas que tengan al menos uno de los géneros de interés
df = df[df[genres].any(axis=1)]

# Convertimos las columnas de géneros en valores booleanos
data = df[genres].astype(bool)

# Creamos el grafico UpSet
upset = UpSet(
    data,
    subset_size='count',
    show_counts=True,
    sort_by='cardinality',
    facecolor="gray",   # color gris de las barras
    element_size=40     # tamaño de las barras
)

# Dibujamos la figura
fig = plt.figure(figsize=(12,8))
upset.plot(fig=fig)

# Añadimos titulo y eje
plt.suptitle(
    "Upset plot: intersecciones de géneros cinematográficos (87 585 películas)\nRéalizado por Mehdi El Mansouri", 
    fontsize=16, fontweight='bold'
)
plt.ylabel("Número de películas", fontsize=12)


# Mostramos el gráfico
plt.show()

